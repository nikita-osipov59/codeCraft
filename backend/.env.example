# Discord OAuth
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# Discord Webhook URL для уведомлений (опционально)
DISCORD_WEBHOOK_URL=your_discord_webhook_url

# PostgreSQL (по умолчанию localhost:5433, postgres/admin)
# Можно переопределить через DATABASE_URL в проде
